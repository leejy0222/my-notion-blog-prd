#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "\n\033[34m➜\033[0m  \033[1mpre-push: Full Test Suite\033[0m\n"

pnpm run lint
if [ $? -ne 0 ]; then
  echo "\033[31m✗\033[0m  Lint 실패"
  exit 1
fi

pnpm run type-check
if [ $? -ne 0 ]; then
  echo "\033[31m✗\033[0m  Type Check 실패"
  exit 1
fi

pnpm run test:unit
if [ $? -ne 0 ]; then
  echo "\033[31m✗\033[0m  단위 테스트 실패"
  exit 1
fi

echo "\n\033[32m✓\033[0m  모든 테스트 통과. Push를 계속합니다.\n"
