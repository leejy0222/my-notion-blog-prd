#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "\n\033[34m➜\033[0m  \033[1mpre-commit: Lint & Type Check\033[0m\n"

pnpm lint-staged

EXIT_CODE=$?
if [ $EXIT_CODE -ne 0 ]; then
  echo "\n\033[31m✗\033[0m  Lint/Type Check 실패. 커밋이 차단되었습니다."
  exit 1
fi

echo "\n\033[32m✓\033[0m  pre-commit 통과\n"
