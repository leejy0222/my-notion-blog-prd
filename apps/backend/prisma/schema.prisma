generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 사용자 모델
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(USER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workflows Workflow[]
  executions Execution[]
  posts     Post[]
  reports   Report[]
}

enum UserRole {
  ADMIN
  USER
  VIEWER
}

// 자동화 워크플로우
model Workflow {
  id          String   @id @default(cuid())
  name        String
  description String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 워크플로우 정의 (JSON)
  definition  Json

  // 상태
  status      WorkflowStatus @default(DRAFT)
  isActive    Boolean        @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  executions  Execution[]

  @@index([userId])
}

enum WorkflowStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// 자동화 실행 기록
model Execution {
  id           String    @id @default(cuid())
  workflowId   String
  workflow     Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 실행 상태
  status       ExecutionStatus @default(PENDING)

  // 실행 결과
  result       Json?
  error        String?

  startedAt    DateTime?
  completedAt  DateTime?
  duration     Int?  // 밀리초 단위

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([workflowId])
  @@index([userId])
  @@index([status])
}

enum ExecutionStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  CANCELLED
}

// 게시글 모델
model Post {
  id        String   @id @default(cuid())
  title     String
  content   String
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reports   Report[]

  @@index([authorId])
}

// 신고 모델
model Report {
  id        String       @id @default(cuid())
  postId    String
  post      Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  reporterId String
  reporter  User         @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  reason    String
  status    ReportStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([postId])
  @@index([reporterId])
  @@index([status])
}

enum ReportStatus {
  PENDING
  RESOLVED
}
